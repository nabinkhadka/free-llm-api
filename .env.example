# ── FreeLLMAPI Environment Variables ───────────────────────────────────
#
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Priority: OS env vars > .env file > YAML defaults (${VAR:-default})
#
# API keys (REQUIRED for providers you want to use):
GROQ_API_KEY=gsk_your_key_here
OPENROUTER_API_KEY=sk-or-your-key-here
NVIDIA_API_KEY=nvapi-your-key-here
MISTRAL_API_KEY=your-mistral-key
ZAI_API_KEY=your-zhipu-key
CEREBRAS_API_KEY=your-cerebras-key
GEMINI_API_KEY=your-gemini-key

# LLM7.io is key-less — no API key needed.

# ── Optional overrides ─────────────────────────────────────────────────
# Model to use (overrides the default in config.yaml):
# GROQ_MODEL=llama-4
# OPENROUTER_MODEL=qwen/qwen3-coder
# NVDIA_MODEL=meta/llama-3.1-8b-instruct
# MISTRAL_MODEL=mistral-small-latest
# ZAI_MODEL=glm-4.5-flash
# CEREBRAS_MODEL=gpt-oss-120b
# LLM7_MODEL=qwen3-235b
# GEMINI_MODEL=gemini-2.5-flash

# Scheduling weight (higher = more traffic; overrides config.yaml):
# GROQ_WEIGHT=10
# OPENROUTER_WEIGHT=6
# NVIDIA_WEIGHT=10
# MISTRAL_WEIGHT=6
# ZAI_WEIGHT=5
# CEREBRAS_WEIGHT=7
# LLM7_WEIGHT=4
# GEMINI_WEIGHT=8
